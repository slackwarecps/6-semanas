# Chave da API Anthropic (Claude) - obrigatória se for usar provedor "claude"
# Gere em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Chave da API DeepSeek - obrigatória se for usar provedor "deepseek"
# Gere em https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Modelo Claude a ser usado (opcional). Default: claude-opus-4-8
ANTHROPIC_MODEL=claude-opus-4-8

# Modelo DeepSeek a ser usado (opcional). Default: deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# Origens permitidas no CORS (opcional, separadas por vírgula). Default: http://localhost:4200
# Em produção, adicione a URL do seu frontend Angular (ex: https://six-week.fabao.eng.br)
ALLOWED_ORIGINS=http://localhost:4200

