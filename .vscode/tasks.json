{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "cd backend && source venv/bin/activate && uvicorn main:app --reload",
      "problemMatcher": [],
      "presentation": {
        "group": "group-dev",
        "panel": "shared"
      }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "npm start",
      "problemMatcher": [],
      "presentation": {
        "group": "group-dev",
        "panel": "shared"
      }
    },
    {
      "label": "Start App (All)",
      "dependsOn": [
        "Start Backend",
        "Start Frontend"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
