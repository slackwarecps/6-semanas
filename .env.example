# Anthropic API key (obrigatório). Gere em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Modelo Claude a ser usado (opcional). Default interno: claude-sonnet-5.
# Alternativas: claude-opus-4-8 (mais capaz, mais caro) | claude-haiku-4-5 (mais rápido/barato)
ANTHROPIC_MODEL=claude-sonnet-5
